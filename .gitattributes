# Scripts sempre com fim de linha LF (rodam no Ubuntu, escritos no Windows)
*.sh   text eol=lf
Makefile text eol=lf

# Arquivos grandes via Git LFS (rode 'git lfs install' antes do primeiro push)
*.mp4    filter=lfs diff=lfs merge=lfs -text
*.pcapng filter=lfs diff=lfs merge=lfs -text
*.bag    filter=lfs diff=lfs merge=lfs -text
*.mcap   filter=lfs diff=lfs merge=lfs -text
